---
import BaseLayout from "../layouts/BaseLayout.astro";
import CuLoo404Mascot from "../components/CuLooMascot/CuLoo404Mascot.astro";

const pageTitle = "404 Not Found";
---

<BaseLayout pageTitle={pageTitle}>
	<main class="not-found">
		<CuLoo404Mascot class="not-found-icon" title="CuLoo 404 mascot" />
	</main>
</BaseLayout>

<style is:global>
	h1 {
		align-items: center;
		justify-content: center;
		text-align: center;
	}

	.not-found {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
	}

	.not-found-icon {
		width: min(280px, 70vw);
		height: auto;
	}
</style>
