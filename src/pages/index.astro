---
import EntryLayout from "../layouts/EntryLayout.astro";

import Greeting from "../components/Greeting";
import CuLooMascot from "../components/CuLooMascot/CuLooMascot.astro";

const pageTitle = "CuLoo's Homepage";
---

<EntryLayout pageTitle={pageTitle}>
	<section class="entry-content" aria-label="首页主内容">
		<div class="entry-mascot" aria-hidden="true">
			<CuLooMascot width="320" height="320" />
		</div>

		<h1 class="entry-title">CuLoo's Homepage</h1>

		<div class="entry-greeting">
			<Greeting
				client:load
				messages={[
					"Hej",
					"Hallo",
					"Hola",
					"Habari",
					"Hi",
					"Hello",
					"Howdy",
					"Hey there",
				]}
			/>
		</div>
	</section>
</EntryLayout>
