---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "随机数生成器";
---

<BaseLayout pageTitle={pageTitle}>
	<section class="random-number-page">
		<p>输入自定义数字范围，并选择随机种子来源后生成结果。</p>

		<div class="input-row">
			<label for="min-number">最小值</label>
			<input id="min-number" type="number" value="1" />
		</div>

		<div class="input-row">
			<label for="max-number">最大值</label>
			<input id="max-number" type="number" value="100" />
		</div>

		<div class="input-row">
			<label for="seed-source">种子来源</label>
			<select id="seed-source">
				<option value="time">时间戳</option>
				<option value="changing">变化值</option>
			</select>
		</div>

		<p>当前变化值：<span id="changing-seed">0</span></p>

		<button id="generate-btn" type="button">生成随机数</button>

		<p>随机结果：<strong id="random-result">-</strong></p>
		<p id="seed-used">使用的种子：-</p>
		<p id="error-message" class="error-message" aria-live="polite"></p>
	</section>

	<script>
		let changingSeed = 0;
		const CHANGING_SEED_UPDATE_INTERVAL_MS = 200;
		const seedSourceLabelMap = {
			time: "时间戳",
			changing: "变化值",
		};
		const changingSeedElement = document.getElementById("changing-seed");
		const minNumberInputElement = document.getElementById("min-number");
		const maxNumberInputElement = document.getElementById("max-number");
		const seedSourceSelectElement = document.getElementById("seed-source");
		const generateButtonElement = document.getElementById("generate-btn");
		const randomResultElement = document.getElementById("random-result");
		const seedUsedElement = document.getElementById("seed-used");
		const errorMessageElement = document.getElementById("error-message");

		const updateChangingSeed = () => {
			changingSeed = Math.floor(performance.now());
			if (changingSeedElement) {
				changingSeedElement.textContent = String(changingSeed);
			}
		};

		/**
		 * 基于 Mulberry32 的轻量级可复现伪随机算法（非安全用途）。
		 * @param {number} seed
		 * @returns {number} [0, 1) 区间内的浮点数
		 */
		const seededRandom = (seed) => {
			let t = seed >>> 0;
			t += 0x6d2b79f5;
			let r = Math.imul(t ^ (t >>> 15), t | 1);
			r ^= r + Math.imul(r ^ (r >>> 7), r | 61);
			return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
		};

		const generateRandomNumber = () => {
			if (
				!(minNumberInputElement instanceof HTMLInputElement) ||
				!(maxNumberInputElement instanceof HTMLInputElement) ||
				!(seedSourceSelectElement instanceof HTMLSelectElement) ||
				!(randomResultElement instanceof HTMLElement) ||
				!(seedUsedElement instanceof HTMLElement) ||
				!(errorMessageElement instanceof HTMLElement)
			) {
				return;
			}

			const min = Number(minNumberInputElement.value);
			const max = Number(maxNumberInputElement.value);

			if (!Number.isFinite(min) || !Number.isFinite(max)) {
				errorMessageElement.textContent = "请输入有效数字范围。";
				return;
			}

			if (!Number.isInteger(min) || !Number.isInteger(max)) {
				errorMessageElement.textContent = "请输入整数范围。";
				return;
			}

			if (min > max) {
				errorMessageElement.textContent = "最小值不能大于最大值。";
				return;
			}

			errorMessageElement.textContent = "";

			const useTimeSeed = seedSourceSelectElement.value === "time";
			const seed = useTimeSeed ? Date.now() : changingSeed;
			const seedLabel =
				seedSourceLabelMap[seedSourceSelectElement.value] ??
				seedSourceSelectElement.value;
			const randomValue = seededRandom(seed);
			const value = Math.floor(randomValue * (max - min + 1)) + min;

			randomResultElement.textContent = String(value);
			seedUsedElement.textContent = `使用的种子：${seed}（${seedLabel}）`;
		};

		updateChangingSeed();
		const changingSeedIntervalId = setInterval(
			updateChangingSeed,
			CHANGING_SEED_UPDATE_INTERVAL_MS
		);
		window.addEventListener("pagehide", () => {
			clearInterval(changingSeedIntervalId);
		});

		if (generateButtonElement instanceof HTMLButtonElement) {
			generateButtonElement.addEventListener("click", generateRandomNumber);
		}
	</script>

	<style>
		.random-number-page {
			max-width: 32rem;
		}

		.input-row {
			display: flex;
			flex-direction: column;
			gap: 0.5rem;
			margin-bottom: 1rem;
		}

		.error-message {
			color: #e53935;
			min-height: 1.5rem;
		}
	</style>
</BaseLayout>
