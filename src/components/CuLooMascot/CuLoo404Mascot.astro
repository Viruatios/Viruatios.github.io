<!-- Star version of the CuLooIcon, used in 404 Not Found, GSAP animated --><!-- Copyright (c) 2026 Viruatios. All rights reserved. -->
<svg
	class="culoo-404-mascot"
	data-culoo-404-mascot
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 200 200"
	width="320"
	height="320"
>
	<defs>
		<!-- 主体六边形渐变 -->
		<radialGradient id="hexGrad" cx="35%" cy="30%" r="75%">
			<stop offset="0%" stop-color="#00ffff"></stop>
			<stop offset="40%" stop-color="#00cfff"></stop>
			<stop offset="100%" stop-color="#0417ff"></stop>
		</radialGradient>

		<!-- 环绕星轨渐变 -->
		<linearGradient id="orbitFrontGrad" x1="0%" y1="0%" x2="100%" y2="0%">
			<stop offset="0%" stop-color="#A78BFA"></stop>
			<stop offset="100%" stop-color="#6D28D9"></stop>
		</linearGradient>
	</defs>

	<g class="mascot-scene">
		<!-- 环绕设计：后半部分星轨 -->
		<g transform="rotate(-15 100 100)">
			<!-- 主轨道 (后) -->
			<path
				d="M 10 100 A 90 35 0 0 1 190 100"
				fill="none"
				stroke="#A78BFA"
				stroke-width="6"
				stroke-linecap="round"
				opacity="0.35"></path>
			<!-- 辅助虚线轨道 (后) -->
			<path
				d="M 25 100 A 75 25 0 0 1 175 100"
				fill="none"
				stroke="#A78BFA"
				stroke-width="2"
				stroke-dasharray="6 6"
				stroke-linecap="round"
				opacity="0.35"></path>
			<!-- 轨道上的小行星 (后) -->
			<circle cx="177.9" cy="82.5" r="4" fill="#A78BFA" opacity="0.5"></circle>
		</g>

		<!-- 吉祥物主体：六边形与面部 -->
		<!-- 整体微微倾斜，看起来像歪头 -->
		<g transform="rotate(6 100 100)">
			<g class="shake-layer">
				<!-- 六边形身体 -->
				<polygon
					points="
						100,50 
						143.3,75 
						143.3,125 
						100,150 
						56.7,125 
						56.7,75
					"
					fill="none"
					stroke="url(#hexGrad)"
					stroke-width="6"
					stroke-linejoin="round"></polygon>

				<!-- 腮红 -->
				<ellipse cx="64" cy="114" rx="10" ry="6" fill="#ffb6c1"></ellipse>
				<ellipse cx="136" cy="114" rx="10" ry="6" fill="#ffb6c1"></ellipse>

				<!-- 面部表情组件 -->
				<g>
					<!-- 眼睛 (豆豆眼) -->
					<ellipse
						class="eye-normal left"
						cx="80"
						cy="97"
						rx="8"
						ry="14"
						fill="#6e69ff"></ellipse>
					<ellipse
						class="eye-normal right"
						cx="120"
						cy="97"
						rx="8"
						ry="14"
						fill="#6e69ff"></ellipse>

					<!-- 眼睛 (><) -->
					<g
						class="eye-cross left"
						fill="none"
						stroke="#6e69ff"
						stroke-width="6"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M 74 90 L 86 97 L 74 104"></path>
					</g>
					<g
						class="eye-cross right"
						fill="none"
						stroke="#6e69ff"
						stroke-width="6"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M 126 90 L 114 97 L 126 104"></path>
					</g>

					<!-- 嘴巴 -->
					<path
						d="M 93 112 Q 100 108 107 112"
						fill="none"
						stroke="#6e69ff"
						stroke-width="3.5"
						stroke-linecap="round"></path>
				</g>
			</g>
		</g>

		<!-- 环绕设计：前半部分星轨 -->
		<g transform="rotate(-15 100 100)">
			<!-- 主轨道 (前) -->
			<path
				d="M 190 100 A 90 35 0 0 1 10 100"
				fill="none"
				stroke="url(#orbitFrontGrad)"
				stroke-width="6"
				stroke-linecap="round"></path>
			<!-- 辅助虚线轨道 (前) -->
			<path
				d="M 175 100 A 75 25 0 0 1 25 100"
				fill="none"
				stroke="#8B5CF6"
				stroke-width="2"
				stroke-dasharray="6 6"
				stroke-linecap="round"></path>
			<!-- 轨道上的小行星 (前) -->
			<circle cx="22" cy="117.5" r="6" fill="#6D28D9"></circle>
			<circle cx="177.9" cy="117.5" r="3.5" fill="#A78BFA"></circle>
			<circle cx="100" cy="135" r="2.5" fill="#8B5CF6"></circle>
		</g>

		<!-- 疑惑标记 -->
		<g transform="rotate(-15 100 100)">
			<text
				x="86"
				y="32"
				fill="#00cfff"
				font-size="36"
				font-weight="700"
				text-anchor="middle"
				dominant-baseline="middle">?</text
			>
			<text
				class="question-exclamation"
				x="104"
				y="32"
				fill="#00cfff"
				font-size="36"
				font-weight="700"
				text-anchor="middle"
				dominant-baseline="middle">!</text
			>
		</g>

		<!-- 背景装饰物：氛围小闪星 -->
		<path
			d="M 160 30 Q 160 35 165 35 Q 160 35 160 40 Q 160 35 155 35 Q 160 35 160 30 Z"
			fill="#FBBF24"></path>
		<path
			d="M 35 60 Q 35 63 38 63 Q 35 63 35 66 Q 35 63 32 63 Q 35 63 35 60 Z"
			fill="#FBBF24"></path>
		<path
			d="M 45 150 Q 45 154 49 154 Q 45 154 45 158 Q 45 154 41 154 Q 45 154 45 150 Z"
			fill="#FBBF24"></path>
		<path
			d="M 165 160 Q 165 163 168 163 Q 165 163 165 166 Q 165 163 162 163 Q 165 163 165 160 Z"
			fill="#FBBF24"></path>
	</g>

	<!-- 生气：三连击后绘制并短暂停留 -->
	<g
		class="anger-symbol"
		fill="none"
		stroke="#ef4444"
		stroke-linecap="round"
		stroke-linejoin="round"
	>
		<!-- 愤怒的脸部表情 -->
		<g stroke-width="6">
			<!-- 左眼 \ -->
			<path d="M 65 78 L 85 83"></path>
			<!-- 右眼 / -->
			<path d="M 135 78 L 115 83"></path>
			<!-- 嘴巴 ⁔ -->
			<path d="M 90 105 Q 100 100 108 103"></path>
			<!-- 嘴角细节 ( -->
			<path d="M 112 98 Q 108 103 112 110"></path>
		</g>

		<!-- 右上角青筋图标 💢 -->
		<g stroke-width="4" transform="rotate(21,155,45)">
			<path d="M 147 33 Q 155 42 163 33"></path>
			<path d="M 167 37 Q 158 45 167 53"></path>
			<path d="M 163 57 Q 155 48 147 57"></path>
			<path d="M 143 53 Q 152 45 143 37"></path>
		</g>
	</g>
</svg>

<script>
	import "../../scripts/culoo404Mascot.js";
</script>
