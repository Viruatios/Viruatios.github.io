---
const mascotColor = "var(--mascot-color)";
---

<!-- Mascot for CuLoo's Homepage --><!-- Copyright (c) 2026 Viruatios. All rights reserved. -->
<svg
	class="culoo-mascot"
	data-culoo-mascot
	xmlns="http://www.w3.org/2000/svg"
	viewBox="-1.6 -1.6 3.2 3.2"
	width="320"
	height="320"
>
	<rect x="-1.6" y="-1.6" width="3.2" height="3.2" fill="none"></rect>

	<!-- 外部层 -->
	<g class="outer-layer">
		<!-- 外接圆分段弧（半径=1.4013） -->
		<g
			class="orbit"
			fill="none"
			stroke={mascotColor}
			stroke-width="0.1"
			stroke-linecap="round"
		>
			<!-- 15°~45° -->
			<path d="M 1.3531 0.3627 A 1.4013 1.4013 0 0 1 0.9911 0.9911"></path>
			<!-- 75°~105° -->
			<path d="M 0.3627 1.3531 A 1.4013 1.4013 0 0 1 -0.3627 1.3531"></path>
			<!-- 135°~165° -->
			<path d="M -0.9911 0.9911 A 1.4013 1.4013 0 0 1 -1.3531 0.3627"></path>
			<!-- 195°~225° -->
			<path d="M -1.3531 -0.3627 A 1.4013 1.4013 0 0 1 -0.9911 -0.9911"></path>
			<!-- 255°~285° -->
			<path d="M -0.3627 -1.3531 A 1.4013 1.4013 0 0 1 0.3627 -1.3531"></path>
			<!-- 315°~345° -->
			<path d="M 0.9911 -0.9911 A 1.4013 1.4013 0 0 1 1.3531 -0.3627"></path>
		</g>
	</g>

	<!-- 面部层 -->
	<g class="face-layer">
		<!-- 正六边形（边长=1，外接圆半径=1） -->
		<polygon
			class="hexagon-body"
			points="
                1,0
                0.5,0.8660254
                -0.5,0.8660254
                -1,0
                -0.5,-0.8660254
                0.5,-0.8660254
            "
			fill="none"
			stroke={mascotColor}
			stroke-width="0.1"
		>
		</polygon>

		<!-- 眼睛 -->
		<g class="eyes">
			<ellipse cx="-0.3" cy="-0.18" rx="0.12" ry="0.28" fill={mascotColor}
			></ellipse>
			<ellipse cx="0.3" cy="-0.18" rx="0.12" ry="0.28" fill={mascotColor}
			></ellipse>
		</g>

		<!-- w小嘴巴（可选项） -->
		<g class="mouth">
			<path
				d="M -0.14 0.08 Q -0.07 0.16 0 0.08 Q 0.07 0.16 0.14 0.08"
				stroke={mascotColor}
				stroke-width="0.06"
				fill="none"
				stroke-linecap="round"
				stroke-linejoin="round"></path>
		</g>

		<!-- 腮红 -->
		<g class="blush">
			<ellipse cx="-0.6" cy="0.1" rx="0.16" ry="0.09" fill="#ffb6c1"></ellipse>
			<ellipse cx="0.6" cy="0.1" rx="0.16" ry="0.09" fill="#ffb6c1"></ellipse>
		</g>
	</g>
</svg>

<script>
	import "../../scripts/culooMascot.js";
</script>
