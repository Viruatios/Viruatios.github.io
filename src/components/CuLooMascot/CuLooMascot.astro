---
const { width, height } = Astro.props;
const mascotColor = "var(--mascot-color)";
const strokeWidth = 7;
---

<!-- Mascot for CuLoo's Homepage --><!-- Copyright (c) 2026 Viruatios. All rights reserved. -->
<svg
	class="culoo-mascot"
	data-culoo-mascot
	data-mascot-ready="false"
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 200 200"
	width={width}
	height={height}
>
	<rect x="0" y="0" width="200" height="200" fill="none"></rect>

	<!-- 外部层 -->
	<g class="outer-layer">
		<g class="outer-layer-scale">
			<g class="outer-layer-translate">
				<g class="outer-layer-rotate">
					<!-- 外接圆分段弧（半径=1.4013） -->
					<g
						class="orbit"
						fill="none"
						stroke={mascotColor}
						stroke-width={strokeWidth}
						stroke-linecap="round"
					>
						<!-- 15°~45° -->
						<path d="M 184.57 122.67 A 87.58 87.58 0 0 1 161.94 161.94"></path>
						<!-- 75°~105° -->
						<path d="M 122.67 184.57 A 87.58 87.58 0 0 1 77.33 184.57"></path>
						<!-- 135°~165° -->
						<path d="M 38.06 161.94 A 87.58 87.58 0 0 1 15.43 122.67"></path>
						<!-- 195°~225° -->
						<path d="M 15.43 77.33 A 87.58 87.58 0 0 1 38.06 38.06"></path>
						<!-- 255°~285° -->
						<path d="M 77.33 15.43 A 87.58 87.58 0 0 1 122.67 15.43"></path>
						<!-- 315°~345° -->
						<path d="M 161.94 38.06 A 87.58 87.58 0 0 1 184.57 77.33"></path>
					</g>
				</g>
			</g>
		</g>
	</g>

	<!-- 面部层 -->
	<g class="face-layer">
		<g class="face-layer-scale">
			<g class="face-layer-translate">
				<g class="face-layer-rotate">
					<!-- 正六边形（边长=1，外接圆半径=1） -->
					<polygon
						class="hexagon-body"
						points="
                162.5,100
                131.25,154.13
                68.75,154.13
                37.5,100
                68.75,45.87
                131.25,45.87
            "
						fill="none"
						stroke={mascotColor}
						stroke-width={strokeWidth}
					>
					</polygon>

					<!-- 眼睛 (豆豆眼) -->
					<g class="eye-normal left">
						<ellipse cx="81.25" cy="88.75" rx="7.5" ry="17.5" fill={mascotColor}
						></ellipse>
					</g>
					<g class="eye-normal right">
						<ellipse
							cx="118.75"
							cy="88.75"
							rx="7.5"
							ry="17.5"
							fill={mascotColor}></ellipse>
					</g>
					<!-- 眼睛 (><) -->
					<g
						class="eye-cross left"
						fill="none"
						stroke={mascotColor}
						stroke-width={strokeWidth}
						stroke-linecap="round"
						stroke-linejoin="round"
						opacity="0"
					>
						<path d="M 75 81.25 L 87.5 88.75 L 75 96.25"></path>
					</g>
					<g
						class="eye-cross right"
						fill="none"
						stroke={mascotColor}
						stroke-width={strokeWidth}
						stroke-linecap="round"
						stroke-linejoin="round"
						opacity="0"
					>
						<path d="M 125 81.25 L 112.5 88.75 L 125 96.25"></path>
					</g>

					<!-- w小嘴巴（可选项） -->
					<g class="mouth">
						<path
							d="M 91.25 105 Q 95.625 110 100 105 Q 104.375 110 108.75 105"
							stroke={mascotColor}
							stroke-width={strokeWidth / 1.667}
							fill="none"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</g>

					<!-- 腮红 -->
					<g class="blush">
						<ellipse cx="62.5" cy="106.25" rx="10" ry="5.625" fill="#ffb6c1"
						></ellipse>
						<ellipse cx="137.5" cy="106.25" rx="10" ry="5.625" fill="#ffb6c1"
						></ellipse>
					</g>
				</g>
			</g>
		</g>
	</g>
</svg>

<script>
	import "../../scripts/culooMascot.ts";
</script>
